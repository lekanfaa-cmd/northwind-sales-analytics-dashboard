          <formatted-text>
            <run fontsize='10'>1. TOP CATEGORIES BY REVENUE</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='categories+' name='federated.0mvdz6j06fmfxy10p40rm1pjm4gl' />
          </datasources>
          <datasource-dependencies datasource='federated.0mvdz6j06fmfxy10p40rm1pjm4gl'>
            <column caption='Discountinued Label' datatype='string' name='[Calculation_0041846006296576]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [discontinued] = 1 THEN &quot;Yes&quot;&#10;ELSE &quot;No&quot;&#10;END' />
            </column>
            <column caption='Revenue' datatype='real' name='[Calculation_0364071424393216]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[unitPrice] * [quantity] * (1 - [discount])' />
