  <worksheets>
    <worksheet name='Average Order Value'>
      <table>
        <view>
          <datasources>
            <datasource caption='categories+' name='federated.0mvdz6j06fmfxy10p40rm1pjm4gl' />
          </datasources>
          <datasource-dependencies datasource='federated.0mvdz6j06fmfxy10p40rm1pjm4gl'>
            <column caption='Revenue' datatype='real' name='[Calculation_0364071424393216]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[unitPrice] * [quantity] * (1 - [discount])' />
            </column>
            <column caption='Average Order Value' datatype='real' name='[Calculation_0364071436124164]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0364071424393216]) / COUNTD([orderID])' />
            </column>
            <column caption='Discount' datatype='real' name='[discount]' role='measure' type='quantitative' />
            <column caption='Order Date' datatype='date' name='[orderDate]' role='dimension' type='ordinal' />
            <column caption='Order ID' datatype='integer' name='[orderID]' role='dimension' type='ordinal' />
            <column caption='Quantity' datatype='integer' name='[quantity]' role='measure' type='quantitative' />
            <column-instance column='[orderDate]' derivation='Month-Trunc' name='[tmn:orderDate:ok]' pivot='key' type='ordinal' />
            <column caption='Unit Price' datatype='real' name='[unitPrice]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0364071436124164]' derivation='User' name='[usr:Calculation_0364071436124164:qk]' pivot='key' type='quantitative' />
            <column-instance column='[orderDate]' derivation='Year' name='[yr:orderDate:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0mvdz6j06fmfxy10p40rm1pjm4gl].[Action (MONTH(Order Date))]'>
            <groupfilter function='level-members' level='[tmn:orderDate:ok]' user:ui-action-filter='[Action6_E4ED62CCDB2448DD91BB66A3E57EFCCA]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.0mvdz6j06fmfxy10p40rm1pjm4gl].[Action (YEAR(Order Date),MONTH(Order Date))]'>
