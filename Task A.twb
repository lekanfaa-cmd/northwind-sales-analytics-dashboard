      <aliases enabled='yes' />
      <column caption='Discountinued Label' datatype='string' name='[Calculation_0041846006296576]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [discontinued] = 1 THEN &quot;Yes&quot;&#10;ELSE &quot;No&quot;&#10;END' />
      </column>
      <column caption='% Calculation' datatype='real' name='[Calculation_0041846011351041]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0364071424393216]) / TOTAL(SUM([Calculation_0364071424393216]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Discontinued %' datatype='real' name='[Calculation_0041846011691010]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [discontinued] = 1 THEN [Calculation_0364071424393216] END' />
      </column>
      <column caption='Discountinued calc. %' datatype='real' name='[Calculation_0041846012485635]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0041846011691010]) / SUM([Calculation_0364071424393216])' />
      </column>
      <column caption='Insight Text' datatype='string' name='[Calculation_0041846013124612]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Discontinued products contribute &quot; &#10;+ STR(ROUND([Calculation_0041846012485635] * 100, 1)) &#10;+ &quot;% of total revenue, indicating potential missed opportunities.&quot;' />
      </column>
      <column caption='Category Rank' datatype='integer' name='[Calculation_0041846020628485]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Calculation_0364071424393216]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top Category Filter' datatype='boolean' name='[Calculation_0041846022033414]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0041846020628485] = 1'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Insight 2' datatype='string' name='[Calculation_0041846022569991]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;The top categories are &quot; &#10;+ LOOKUP(ATTR([categoryName]), FIRST()) &#10;+ &quot; and &quot; &#10;+ LOOKUP(ATTR([categoryName]), FIRST()+1)&#10;+ &quot;, together contributing &quot;&#10;+ STR(ROUND(WINDOW_SUM([Calculation_0041846011351041], FIRST(), FIRST()+1) * 100, 1))&#10;+ &quot;% of total revenue.&quot;'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top Product Filter' datatype='boolean' name='[Calculation_0041846044651530]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0041846044958731] = 1'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Product Rank' datatype='integer' name='[Calculation_0041846044958731]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Calculation_0364071424393216]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top Product Insight' datatype='string' name='[Calculation_0041846045216780]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;&quot;&#10;+ ATTR([productName])&#10;+ &quot; is the top-performing product with &quot;&#10;+ [Calculation_0041846045675533]&#10;+ &quot; in revenue.&quot;' />
      </column>
      <column caption='Formatted Revenue' datatype='string' name='[Calculation_0041846045675533]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Calculation_0364071424393216]) &gt;= 1000 THEN&#10;&quot;$&quot; + STR(ROUND(SUM([Calculation_0364071424393216]) / 1000, 1)) + &quot;K&quot;&#10;ELSE&#10;&quot;$&quot; + STR(ROUND(SUM([Calculation_0364071424393216]), 0))&#10;END' />
      </column>
      <column caption='Shipping Time' datatype='integer' name='[Calculation_0041846162857998]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [orderDate], [shippedDate])' />
      </column>
      <column caption='City Rank' datatype='integer' name='[Calculation_0041846218436623]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Calculation_0364071424393216]))'>
