      <column caption='Top City Insight' datatype='string' name='[Calculation_0041846218706961]' role='measure' type='nominal'>
        <calculation class='tableau' formula='ATTR([city]) &#10;+ &quot; is the top-performing city with &quot;&#10;+ &#10;IF SUM([Calculation_0364071424393216]) &gt;= 1000 THEN&#10;&quot;$&quot; + STR(ROUND(SUM([Calculation_0364071424393216]) / 1000, 0)) + &quot;K&quot;&#10;ELSE&#10;&quot;$&quot; + STR(ROUND(SUM([Calculation_0364071424393216]), 0))&#10;END&#10;+ &quot; in revenue.&quot;' />
      </column>
      <column caption='Month Rank' datatype='integer' name='[Calculation_0099845727584256]' role='measure' type='quantitative'>
